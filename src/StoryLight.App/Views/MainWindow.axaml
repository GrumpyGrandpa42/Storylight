<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="StoryLight.App.Views.MainWindow"
        x:Name="RootWindow"
        Width="1360"
        Height="860"
        MinWidth="1080"
        MinHeight="720"
        Icon="avares://StoryLight.App/Assets/Icon.png"
        Title="StoryLight">
  <Grid Background="#E9DFC8" ColumnDefinitions="Auto,*">
    <Border Grid.Column="0"
            Margin="18"
            Width="28"
            Background="#E1D3B5"
            BorderBrush="#C7B89C"
            BorderThickness="1"
            CornerRadius="12"
            IsVisible="{Binding IsLibraryCollapsed}">
      <Button Classes="edgeTab"
              Content="›"
              Command="{Binding ToggleLibraryPaneCommand}"
              ToolTip.Tip="Show library" />
    </Border>

    <Border Grid.Column="0"
            Margin="18"
            Width="320"
            Background="#F1E7D1"
            BorderBrush="#C7B89C"
            BorderThickness="1"
            CornerRadius="12"
            Padding="14"
            IsVisible="{Binding IsLibraryVisible}">
      <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
          <TextBlock Text="Library" FontSize="22" FontWeight="Bold" />
          <Button Grid.Column="1"
                  Classes="icon"
                  Width="40"
                  Height="40"
                  Margin="10,0,0,0"
                  Content="+"
                  Command="{Binding ImportDocumentCommand}"
                  ToolTip.Tip="Import document" />
          <Button Grid.Column="2"
                  Classes="icon"
                  Width="40"
                  Height="40"
                  Margin="8,0,0,0"
                  Content="‹"
                  Command="{Binding ToggleLibraryPaneCommand}"
                  ToolTip.Tip="Hide library" />
          <TextBlock Grid.Row="1"
                     Grid.ColumnSpan="3"
                     Margin="0,6,0,0"
                     Text="Recent books and documents with saved progress."
                     Foreground="#6B5B45"
                     TextWrapping="Wrap" />
        </Grid>

        <ListBox Grid.Row="1"
                 Margin="0,14,0,0"
                 ItemsSource="{Binding LibraryItems}"
                 SelectedItem="{Binding SelectedLibraryItem}"
                 DoubleTapped="OnLibraryDoubleTapped">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Background="#FFF9ED"
                      BorderBrush="#D5C6A8"
                      BorderThickness="1"
                      CornerRadius="10"
                      Margin="0,0,0,10"
                      Padding="10"
                      PointerPressed="OnLibraryItemPointerPressed">
                <Grid ColumnDefinitions="72,*">
                  <Border Width="72" Height="100" CornerRadius="8" Background="#E6D9BD" BorderBrush="#C9BA9C" BorderThickness="1">
                    <Grid>
                      <Image Source="{Binding CoverBitmap}" Stretch="UniformToFill" IsVisible="{Binding HasCoverImage}" />
                      <TextBlock Text="{Binding FormatLabel}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 FontWeight="Bold"
                                 Foreground="#7A6548"
                                 IsVisible="{Binding HasNoCoverImage}" />
                    </Grid>
                  </Border>

                  <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="4">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Subtitle}" Foreground="#6B5B45" FontSize="12" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ProgressText}" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LastOpenedDisplay}" FontSize="11" Foreground="#8B7758" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Grid Grid.Column="1" Margin="0,18,18,18" RowDefinitions="Auto,*,Auto">
      <Grid Margin="0,0,0,18" ColumnDefinitions="*,Auto">
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding DocumentTitle}" FontSize="28" FontWeight="Bold" TextWrapping="Wrap" />
          <TextBlock Text="{Binding DocumentSubtitle}" FontSize="15" Foreground="#6B5B45" TextWrapping="Wrap" />
        </StackPanel>

        <Button Grid.Column="1"
                Classes="icon"
                Width="48"
                Height="48"
                Margin="16,0,0,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                ToolTip.Tip="Voice controls">
          <Button.Flyout>
            <Flyout Placement="LeftEdgeAlignedTop">
              <Border Classes="voiceFlyout"
                      Padding="12">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="12">
                  <StackPanel Width="180"
                              Spacing="2"
                              VerticalAlignment="Center">
                    <TextBlock Text="Voice Controls" FontWeight="Bold" />
                    <TextBlock Text="Read aloud and tune playback."
                               FontSize="12"
                               Foreground="#6B5B45"
                               TextWrapping="Wrap" />
                  </StackPanel>

                  <StackPanel Width="190"
                              Spacing="4"
                              VerticalAlignment="Center">
                    <TextBlock Text="Voice" FontWeight="SemiBold" FontSize="12" />
                    <ComboBox ItemsSource="{Binding TtsVoices}"
                              SelectedItem="{Binding SelectedTtsVoice}"
                              IsEnabled="{Binding IsTextToSpeechAvailable}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>

                  <StackPanel Width="96"
                              Spacing="4"
                              VerticalAlignment="Center">
                    <TextBlock Text="Speed" FontWeight="SemiBold" FontSize="12" />
                    <ComboBox ItemsSource="{Binding SpeechRates}"
                              SelectedItem="{Binding SpeechRate}" />
                  </StackPanel>

                  <StackPanel Spacing="6"
                              VerticalAlignment="Center">
                    <TextBlock Text="Playback" FontWeight="SemiBold" FontSize="12" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Button Classes="icon"
                              Width="40"
                              Height="40"
                              Content="▶"
                              Command="{Binding ReadAloudCommand}"
                              ToolTip.Tip="Read aloud" />
                      <Button Classes="icon"
                              Width="40"
                              Height="40"
                              Content="⏸"
                              Command="{Binding PauseSpeechCommand}"
                              ToolTip.Tip="Pause" />
                      <Button Classes="icon"
                              Width="40"
                              Height="40"
                              Content="⏵"
                              Command="{Binding ResumeSpeechCommand}"
                              ToolTip.Tip="Resume" />
                      <Button Classes="icon"
                              Width="40"
                              Height="40"
                              Content="⏹"
                              Command="{Binding StopSpeechCommand}"
                              ToolTip.Tip="Stop" />
                    </StackPanel>
                  </StackPanel>

                  <CheckBox Content="Next page"
                            VerticalAlignment="Center"
                            IsChecked="{Binding ContinueToNextPage}" />

                  <Button Classes="toolbar"
                          VerticalAlignment="Center"
                          Content="Voices Folder"
                          Command="{Binding OpenVoicesFolderCommand}" />
                </StackPanel>
              </Border>
            </Flyout>
          </Button.Flyout>
          
          <Grid Width="22" Height="22">
            <Path Data="M2,9 L7,9 L12,4 L12,18 L7,13 L2,13 Z"
                  Fill="#2D241A"
                  Stretch="Fill" />
            <Path Data="M15,8 C17,10 17,12 15,14"
                  Stroke="#2D241A"
                  StrokeThickness="1.7"
                  StrokeLineCap="Round" />
            <Path Data="M17.5,5.5 C21.5,9 21.5,13 17.5,16.5"
                  Stroke="#2D241A"
                  StrokeThickness="1.7"
                  StrokeLineCap="Round" />
          </Grid>
        </Button>
      </Grid>

      <Grid Grid.Row="1" Margin="0,0,0,18" ColumnDefinitions="*,Auto">
        <Grid RowDefinitions="Auto,*">
          <StackPanel HorizontalAlignment="Center" Spacing="6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
              <Button Classes="icon"
                      Width="40"
                      Height="40"
                      Content="←"
                      Command="{Binding PreviousPageCommand}"
                      ToolTip.Tip="Previous page" />
              <Button Classes="chapterHeading"
                      Click="OnChapterHeadingClick"
                      IsVisible="{Binding CanOpenChapterList}"
                      ToolTip.Tip="Choose chapter">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="8">
                  <TextBlock Text="{Binding CurrentChapterTitle}"
                             FontSize="18"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <TextBlock Text="▼"
                             FontSize="11"
                             Foreground="#6B5B45"
                             VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Classes="icon"
                      Width="40"
                      Height="40"
                      Content="→"
                      Command="{Binding NextPageCommand}"
                      ToolTip.Tip="Next page" />
            </StackPanel>
            <TextBlock Text="{Binding PageStatus}"
                       FontWeight="SemiBold"
                       Foreground="#6B5B45"
                       HorizontalAlignment="Center" />
          </StackPanel>

          <Border Grid.Row="1" Classes="page" Padding="30" Margin="0,12,0,0">
            <ScrollViewer>
              <TextBlock Text="{Binding PageText}"
                         TextWrapping="Wrap"
                         FontSize="{Binding ReaderFontSize}"
                         LineHeight="{Binding ReaderFontSize}"
                         FontFamily="Georgia, Times New Roman, Serif" />
            </ScrollViewer>
          </Border>

        </Grid>

        <Border Grid.Column="1"
                Margin="18,0,0,0"
                Width="82"
                Background="#F1E7D1"
                BorderBrush="#C7B89C"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Stretch" Spacing="10">
            <TextBlock Text="500%" HorizontalAlignment="Center" Foreground="#6B5B45" />
            <Slider Minimum="25"
                    Maximum="500"
                    Value="{Binding ZoomPercent}"
                    Orientation="Vertical"
                    Width="40"
                    Height="272"
                    SmallChange="5"
                    LargeChange="25"
                    TickFrequency="25" />
            <TextBlock Text="{Binding ZoomDisplay}" HorizontalAlignment="Center" FontWeight="SemiBold" />
            <TextBlock Text="25%" HorizontalAlignment="Center" Foreground="#6B5B45" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Row="2"
              Background="#F1E7D1"
              BorderBrush="#C7B89C"
              BorderThickness="1"
              CornerRadius="12"
              Padding="12">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Text="{Binding Status}"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center" />
          <Button Grid.Column="1"
                  Classes="icon"
                  Width="40"
                  Height="40"
                  Margin="10,0,0,0"
                  Content="←"
                  Command="{Binding PreviousPageCommand}"
                  ToolTip.Tip="Previous page" />
          <Button Grid.Column="2"
                  Classes="icon"
                  Width="40"
                  Height="40"
                  Margin="10,0,0,0"
                  Content="→"
                  Command="{Binding NextPageCommand}"
                  ToolTip.Tip="Next page" />
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
