<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="StoryLight.App.App">
  <Application.Styles>
    <SimpleTheme />
    <Style Selector="Window">
      <Setter Property="Background" Value="#F4EEDF" />
      <Setter Property="Foreground" Value="#2D241A" />
    </Style>
    <Style Selector="Border.page">
      <Setter Property="Background" Value="#FFF9ED" />
      <Setter Property="BorderBrush" Value="#C7B89C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="BoxShadow" Value="0 10 30 0 #22000000" />
    </Style>
    <Style Selector="Border.voiceFlyout">
      <Setter Property="Background" Value="#FFF9ED" />
      <Setter Property="BorderBrush" Value="#C7B89C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BoxShadow" Value="0 12 32 0 #26000000" />
    </Style>
    <Style Selector="Button.toolbar">
      <Setter Property="MinWidth" Value="80" />
    </Style>
    <Style Selector="Button.chapterHeading">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.icon">
      <Setter Property="MinWidth" Value="40" />
      <Setter Property="MinHeight" Value="40" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.edgeTab">
      <Setter Property="MinWidth" Value="28" />
      <Setter Property="MinHeight" Value="120" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Application.Styles>
</Application>
