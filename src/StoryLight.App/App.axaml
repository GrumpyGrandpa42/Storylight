<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="StoryLight.App.App">
  <Application.Styles>
    <SimpleTheme />
    <Style Selector="Window">
      <Setter Property="Background" Value="#F4EEDF" />
      <Setter Property="Foreground" Value="#2D241A" />
    </Style>
    <Style Selector="Border.page">
      <Setter Property="Background" Value="#FFF9ED" />
      <Setter Property="BorderBrush" Value="#C7B89C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="BoxShadow" Value="0 10 30 0 #22000000" />
    </Style>
    <Style Selector="Button.toolbar">
      <Setter Property="MinWidth" Value="80" />
    </Style>
  </Application.Styles>
</Application>
