<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="StoryLight.App.Views.MainWindow"
        x:Name="RootWindow"
        Width="1360"
        Height="860"
        MinWidth="1080"
        MinHeight="720"
        Icon="avares://StoryLight.App/Assets/Icon.png"
        Title="StoryLight">
  <Grid Background="#E9DFC8" ColumnDefinitions="Auto,*">
    <Border Grid.Column="0"
            Margin="18"
            Width="28"
            Background="#E1D3B5"
            BorderBrush="#C7B89C"
            BorderThickness="1"
            CornerRadius="12"
            IsVisible="{Binding IsLibraryCollapsed}">
      <Button Classes="edgeTab"
              Content="›"
              Command="{Binding ToggleLibraryPaneCommand}"
              ToolTip.Tip="Show library" />
    </Border>

    <Border Grid.Column="0"
            Margin="18"
            Width="320"
            Background="#F1E7D1"
            BorderBrush="#C7B89C"
            BorderThickness="1"
            CornerRadius="12"
            Padding="14"
            IsVisible="{Binding IsLibraryVisible}">
      <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
          <TextBlock Text="Library" FontSize="22" FontWeight="Bold" />
          <Button Grid.Column="1"
                  Classes="icon"
                  Width="40"
                  Height="40"
                  Margin="10,0,0,0"
                  Content="+"
                  Command="{Binding ImportDocumentCommand}"
                  ToolTip.Tip="Import document" />
          <Button Grid.Column="2"
                  Classes="icon"
                  Width="40"
                  Height="40"
                  Margin="8,0,0,0"
                  Content="‹"
                  Command="{Binding ToggleLibraryPaneCommand}"
                  ToolTip.Tip="Hide library" />
          <TextBlock Grid.Row="1"
                     Grid.ColumnSpan="3"
                     Margin="0,6,0,0"
                     Text="Recent books and documents with saved progress."
                     Foreground="#6B5B45"
                     TextWrapping="Wrap" />
        </Grid>

        <ListBox Grid.Row="1"
                 Margin="0,14,0,0"
                 ItemsSource="{Binding LibraryItems}"
                 SelectedItem="{Binding SelectedLibraryItem}"
                 DoubleTapped="OnLibraryDoubleTapped">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Background="#FFF9ED"
                      BorderBrush="#D5C6A8"
                      BorderThickness="1"
                      CornerRadius="10"
                      Margin="0,0,0,10"
                      Padding="10"
                      PointerPressed="OnLibraryItemPointerPressed">
                <Grid ColumnDefinitions="72,*">
                  <Border Width="72" Height="100" CornerRadius="8" Background="#E6D9BD" BorderBrush="#C9BA9C" BorderThickness="1">
                    <Grid>
                      <Image Source="{Binding CoverBitmap}" Stretch="UniformToFill" IsVisible="{Binding HasCoverImage}" />
                      <TextBlock Text="{Binding FormatLabel}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 FontWeight="Bold"
                                 Foreground="#7A6548"
                                 IsVisible="{Binding HasNoCoverImage}" />
                    </Grid>
                  </Border>

                  <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="4">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Subtitle}" Foreground="#6B5B45" FontSize="12" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ProgressText}" FontSize="12" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LastOpenedDisplay}" FontSize="11" Foreground="#8B7758" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Grid Grid.Column="1" Margin="0,18,18,18" RowDefinitions="Auto,Auto,*,Auto">
      <Border Background="#E1D3B5"
              BorderBrush="#C7B89C"
              BorderThickness="1"
              CornerRadius="12"
              Padding="14">
        <Grid RowDefinitions="Auto,Auto">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="icon"
                    Width="40"
                    Height="40"
                    Content="←"
                    Command="{Binding PreviousPageCommand}"
                    ToolTip.Tip="Previous page" />
            <Button Classes="icon"
                    Width="40"
                    Height="40"
                    Content="→"
                    Command="{Binding NextPageCommand}"
                    ToolTip.Tip="Next page" />
            <ComboBox Width="220"
                      ItemsSource="{Binding TtsVoices}"
                      SelectedItem="{Binding SelectedTtsVoice}"
                      IsEnabled="{Binding IsTextToSpeechAvailable}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox Width="84" ItemsSource="{Binding SpeechRates}" SelectedItem="{Binding SpeechRate}" />
            <Button Classes="icon"
                    Width="40"
                    Height="40"
                    Content="▶"
                    Command="{Binding ReadAloudCommand}"
                    ToolTip.Tip="Read aloud" />
            <Button Classes="icon"
                    Width="40"
                    Height="40"
                    Content="⏸"
                    Command="{Binding PauseSpeechCommand}"
                    ToolTip.Tip="Pause" />
            <Button Classes="icon"
                    Width="40"
                    Height="40"
                    Content="⏵"
                    Command="{Binding ResumeSpeechCommand}"
                    ToolTip.Tip="Resume" />
            <Button Classes="icon"
                    Width="40"
                    Height="40"
                    Content="⏹"
                    Command="{Binding StopSpeechCommand}"
                    ToolTip.Tip="Stop" />
            <Button Classes="icon"
                    Width="40"
                    Height="40"
                    Content="⋯"
                    Command="{Binding ToggleReaderOptionsCommand}"
                    ToolTip.Tip="Reader options" />
          </StackPanel>

          <Border Grid.Row="1"
                  Margin="0,12,0,0"
                  Padding="12"
                  Background="#F5ECD8"
                  BorderBrush="#C7B89C"
                  BorderThickness="1"
                  CornerRadius="10"
                  IsVisible="{Binding IsReaderOptionsOpen}">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
              <Button Classes="toolbar"
                      Content="Voices Folder"
                      Command="{Binding OpenVoicesFolderCommand}" />
              <CheckBox Content="Continue to next page"
                        IsChecked="{Binding ContinueToNextPage}"
                        VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <StackPanel Grid.Row="1" Margin="0,18,0,0" Spacing="6">
        <TextBlock Text="{Binding DocumentTitle}" FontSize="28" FontWeight="Bold" TextWrapping="Wrap" />
        <TextBlock Text="{Binding DocumentSubtitle}" FontSize="15" Foreground="#6B5B45" TextWrapping="Wrap" />
      </StackPanel>

      <Grid Grid.Row="2" Margin="0,18,0,18" ColumnDefinitions="*,Auto">
        <Grid RowDefinitions="Auto,*">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="{Binding PageTitle}" FontSize="18" FontWeight="SemiBold" IsVisible="{Binding HasPageTitle}" />
            <TextBlock Grid.Column="1" Text="{Binding PageStatus}" FontWeight="SemiBold" Foreground="#6B5B45" />
          </Grid>

          <Border Grid.Row="1" Classes="page" Padding="30" Margin="0,12,0,0">
            <ScrollViewer>
              <TextBlock Text="{Binding PageText}"
                         TextWrapping="Wrap"
                         FontSize="{Binding ReaderFontSize}"
                         LineHeight="{Binding ReaderFontSize}"
                         FontFamily="Georgia, Times New Roman, Serif" />
            </ScrollViewer>
          </Border>
        </Grid>

        <Border Grid.Column="1"
                Margin="18,0,0,0"
                Width="88"
                Background="#F1E7D1"
                BorderBrush="#C7B89C"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Stretch" Spacing="10">
            <TextBlock Text="500%" HorizontalAlignment="Center" Foreground="#6B5B45" />
            <Slider Minimum="25"
                    Maximum="500"
                    Value="{Binding ZoomPercent}"
                    Orientation="Vertical"
                    Width="40"
                    Height="320"
                    SmallChange="5"
                    LargeChange="25"
                    TickFrequency="25" />
            <TextBlock Text="{Binding ZoomDisplay}" HorizontalAlignment="Center" FontWeight="SemiBold" />
            <TextBlock Text="25%" HorizontalAlignment="Center" Foreground="#6B5B45" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Row="3"
              Background="#F1E7D1"
              BorderBrush="#C7B89C"
              BorderThickness="1"
              CornerRadius="12"
              Padding="12">
        <TextBlock Text="{Binding Status}" TextWrapping="Wrap" />
      </Border>
    </Grid>
  </Grid>
</Window>
